@prefix : <http://www.semanticweb.org/motor/ontologies/2026/1/untitled-ontology-2/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/motor/ontologies/2026/1/untitled-ontology-2/> .

<http://www.pelda.hu/intelligens-utikonyv> rdf:type owl:Ontology .

#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/motor/ontologies/2026/1/untitled-ontology-2/reszeAnnak
:reszeAnnak rdf:type owl:ObjectProperty ,
                     owl:TransitiveProperty ;
            rdfs:domain :FoldrajziElhelyezkedes ;
            rdfs:range :FoldrajziElhelyezkedes .


###  http://www.semanticweb.org/motor/ontologies/2026/1/untitled-ontology-2/talalhato
:talalhato rdf:type owl:ObjectProperty ;
           owl:inverseOf :vanHelyszine ;
           rdfs:domain :Helyszin ;
           rdfs:range :Telepules .


###  http://www.semanticweb.org/motor/ontologies/2026/1/untitled-ontology-2/vanHelyszine
:vanHelyszine rdf:type owl:ObjectProperty ;
              rdfs:domain :Telepules ;
              rdfs:range :Helyszin .


#################################################################
#    Data properties
#################################################################

###  http://www.semanticweb.org/motor/ontologies/2026/1/untitled-ontology-2/leiras
:leiras rdf:type owl:DatatypeProperty ;
        rdfs:range xsd:string .


###  http://www.semanticweb.org/motor/ontologies/2026/1/untitled-ontology-2/nev
:nev rdf:type owl:DatatypeProperty ;
     rdfs:range xsd:string .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/motor/ontologies/2026/1/untitled-ontology-2/Etterem
:Etterem rdf:type owl:Class ;
         rdfs:subClassOf :Szolgaltatas .


###  http://www.semanticweb.org/motor/ontologies/2026/1/untitled-ontology-2/FoldrajziElhelyezkedes
:FoldrajziElhelyezkedes rdf:type owl:Class .


###  http://www.semanticweb.org/motor/ontologies/2026/1/untitled-ontology-2/Helyszin
:Helyszin rdf:type owl:Class .


###  http://www.semanticweb.org/motor/ontologies/2026/1/untitled-ontology-2/Latnivalo
:Latnivalo rdf:type owl:Class ;
           rdfs:subClassOf :Helyszin .


###  http://www.semanticweb.org/motor/ontologies/2026/1/untitled-ontology-2/Muemlek
:Muemlek rdf:type owl:Class ;
         rdfs:subClassOf :Latnivalo .


###  http://www.semanticweb.org/motor/ontologies/2026/1/untitled-ontology-2/Muzeum
:Muzeum rdf:type owl:Class ;
        rdfs:subClassOf :Latnivalo .


###  http://www.semanticweb.org/motor/ontologies/2026/1/untitled-ontology-2/Szallas
:Szallas rdf:type owl:Class ;
         rdfs:subClassOf :Szolgaltatas .


###  http://www.semanticweb.org/motor/ontologies/2026/1/untitled-ontology-2/Szolgaltatas
:Szolgaltatas rdf:type owl:Class ;
              rdfs:subClassOf :Helyszin .


###  http://www.semanticweb.org/motor/ontologies/2026/1/untitled-ontology-2/Telepules
:Telepules rdf:type owl:Class ;
           rdfs:subClassOf :FoldrajziElhelyezkedes .


###  http://www.semanticweb.org/motor/ontologies/2026/1/untitled-ontology-2/Varmegye
:Varmegye rdf:type owl:Class ;
          rdfs:subClassOf :FoldrajziElhelyezkedes .


#################################################################
#    Individuals
#################################################################

###  http://www.semanticweb.org/motor/ontologies/2026/1/untitled-ontology-2/Bacs_Kiskun_varmegye
:Bacs_Kiskun_varmegye rdf:type owl:NamedIndividual ,
                               :Varmegye ;
                      :nev "Bács-Kiskun vármegye" .


###  http://www.semanticweb.org/motor/ontologies/2026/1/untitled-ontology-2/Balassagyarmat
:Balassagyarmat rdf:type owl:NamedIndividual ,
                         :Telepules ;
                :reszeAnnak :Nograd_varmegye ;
                :nev "Balassagyarmat" .


###  http://www.semanticweb.org/motor/ontologies/2026/1/untitled-ontology-2/Bambara_Hotel
:Bambara_Hotel rdf:type owl:NamedIndividual ,
                        :Szallas ;
               :talalhato :Felsotarkany ;
               :leiras "Egyedülálló afrikai tematikájú luxusszálloda a bükki erdők ölelésében, különleges wellness élményekkel." ;
               :nev "Bambara Hotel" .


###  http://www.semanticweb.org/motor/ontologies/2026/1/untitled-ontology-2/Banyamuzeum
:Banyamuzeum rdf:type owl:NamedIndividual ,
                      :Muzeum ;
             :talalhato :Salgotarjan ;
             :leiras "Magyarország első föld alatti bányamúzeuma, amely egy valódi lejtősaknát mutat be a látogatóknak." ;
             :nev "Bányamúzeum" .


###  http://www.semanticweb.org/motor/ontologies/2026/1/untitled-ontology-2/Baranya_varmegye
:Baranya_varmegye rdf:type owl:NamedIndividual ,
                           :Varmegye ;
                  :nev "Baranya vármegye" .


