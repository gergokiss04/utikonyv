                         :Varmegye ;
                :nev "Békés vármegye" .


###  http://www.semanticweb.org/motor/ontologies/2026/1/untitled-ontology-2/BoriMami
:BoriMami rdf:type owl:NamedIndividual ,
                   :Etterem ;
          :talalhato :Gyongyos ;
          :leiras "Országos hírű gasztronómiai találkozóhely a város szívében, ahol a hagyományos alapanyagokat modern stílusban tálalják." ;
          :nev "BoriMami" .


###  http://www.semanticweb.org/motor/ontologies/2026/1/untitled-ontology-2/Borsod_Abauj_Zemplen_varmegye
:Borsod_Abauj_Zemplen_varmegye rdf:type owl:NamedIndividual ,
                                        :Varmegye ;
                               :nev "Borsod-Abaúj-Zemplén vármegye" .


###  http://www.semanticweb.org/motor/ontologies/2026/1/untitled-ontology-2/Bunbano_Szent_Maria_Magdolna_Templom
:Bunbano_Szent_Maria_Magdolna_Templom rdf:type owl:NamedIndividual ,
                                               :Muemlek ;
                                      :talalhato :Felsotarkany ;
                                      :leiras "A barokk templomot 1785-90 között építtette Eszterházy Károly. Az oltárokat 1793-ra készítette el Giacomo és Giovanni Adami, kőszobrait Mózer József faragta." ;
                                      :nev "Bűnbánó Szent Mária Magdolna Templom" .


###  http://www.semanticweb.org/motor/ontologies/2026/1/untitled-ontology-2/Castellum_Hotel
:Castellum_Hotel rdf:type owl:NamedIndividual ,
                          :Szallas ;
                 :talalhato :Holloko ;
                 :leiras "Modern, minden igényt kielégítő wellness szálloda, amely tökéletesen illeszkedik a történelmi környezetbe." ;
                 :nev "Castellum Hotel" .


###  http://www.semanticweb.org/motor/ontologies/2026/1/untitled-ontology-2/Ciszterci_Monostor
